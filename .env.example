# ==========================================
# Environment Variables — Development
# ==========================================

# Application
NODE_ENV=development
APP_PORT=3000
APP_NAME=Tekstil Üretim Takip Sistemi
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Database — PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=imalat_user
DB_PASSWORD=imalat_pass_2026
DB_NAME=imalat_db
DATABASE_URL=postgresql://imalat_user:imalat_pass_2026@localhost:5432/imalat_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=imalat_redis_2026

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2026
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-2026
JWT_REFRESH_EXPIRES_IN=7d

# MinIO (S3)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=imalat_minio
MINIO_ROOT_PASSWORD=imalat_minio_2026
MINIO_BUCKET=imalat-files

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_LOGIN_TTL=60
THROTTLE_LOGIN_LIMIT=5

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel
